datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // was Role enum
  status    String   // was Status enum
  records   Record[] // relation
  createdAt DateTime @default(now())
}

model Record {
  id        String   @id @default(uuid())
  amount    Float
  type      String   // was RecordType enum
  category  String
  date      DateTime
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])
}